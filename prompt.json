[
  {
    "role": "system",
    "content": {{ system_message | dump }}
  },
  {% for completion in _conversation %}
  {
    "role": "user",
    "content": {{ completion.input | dump }}
  },
  {
    "role": "assistant",
    "content": {{ completion.output | dump }}
  },
  {% endfor %}
  {
    "role": "user",
    "content": {{ message | dump }}
  }
]
